# Copie este arquivo para ".env" e preencha com seus valores reais.
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore).

# Porta da API
PORT=3000

# Caminho do banco de dados SQLite (criado automaticamente)
DB_PATH=./newdatabase.db

# Credenciais SMTP para envio da passagem digital por e-mail
# Para Gmail, gere uma "senha de app" em https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app

# HTTPS opcional — descomente e aponte para seus certificados locais
# HTTPS_PORT=3001
# SSL_KEY_PATH=./assets/SSL/code.key
# SSL_CERT_PATH=./assets/SSL/code.crt
