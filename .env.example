# Copie este arquivo para ".env" e preencha com seus valores reais.
# O .env nunca deve ser commitado (já está no .gitignore).

# PostgreSQL — crie um banco gratuito em https://supabase.com (ou https://neon.tech)
# No Supabase: botão "Connect" → aba ORMs → Prisma. Caracteres especiais na senha
# precisam ser URL-encodados (ex.: @ vira %40).
# App em runtime (transaction pooler, porta 6543):
DATABASE_URL="postgresql://usuario:senha@host:6543/postgres?pgbouncer=true"
# Migrações e seed (session pooler, porta 5432):
DIRECT_URL="postgresql://usuario:senha@host:5432/postgres"

# Segredo usado para assinar os tokens de sessão (use um valor longo e aleatório)
# Gere um com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# URL pública da aplicação (usada nos links de e-mail)
APP_URL="http://localhost:3000"

# Credenciais SMTP para envio das passagens por e-mail (opcional)
# Para Gmail, gere uma "senha de app" em https://myaccount.google.com/apppasswords
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER=""
EMAIL_PASS=""
